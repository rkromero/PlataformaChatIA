generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/ai-bot-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CONTROL_PLANE_DB_URL")
}

enum TenantStatus {
  active
  paused
}

enum TenantPlan {
  trial
  starter
  pro
  enterprise
}

enum ChannelType {
  whatsapp
  whatsapp_qr
  webchat
}

enum MessageDirection {
  incoming
  outgoing
}

enum ConversationSource {
  chatwoot
  whatsapp_qr
  manual
}

model Tenant {
  id                    String       @id @db.Uuid
  name                  String
  slug                  String?      @unique
  status                TenantStatus
  plan                  TenantPlan
  modulesJson           Json         @default("{}") @map("modules_json") @db.JsonB
  chatwootAccountId     Int?         @unique @map("chatwoot_account_id")
  onboardingCompleted   Boolean      @default(false) @map("onboarding_completed")
  trialEndsAt           DateTime?    @map("trial_ends_at")
  createdAt             DateTime     @map("created_at")
  updatedAt             DateTime     @map("updated_at")
  deletedAt             DateTime?    @map("deleted_at")

  aiSettings        AiSettings?
  calendarConfig    CalendarConfig?
  channels          TenantChannel[]
  conversationLinks ConversationLink[]
  messages          Message[]
  usageRecords      UsageRecord[]
  knowledgeEntries  KnowledgeEntry[]
  dailyUsage        DailyUsage[]
  baileysAuths      BaileysAuth[]
  tenantUsers       TenantUser[]
  calendarServices  CalendarService[]
  appointments      Appointment[]

  @@map("tenants")
}

model AiSettings {
  tenantId             String   @id @map("tenant_id") @db.Uuid
  enabled              Boolean
  model                String
  systemPrompt         String   @map("system_prompt") @db.Text
  handoffRulesJson     Json     @map("handoff_rules_json") @db.JsonB
  businessHoursJson    Json?    @map("business_hours_json") @db.JsonB
  removeOpeningSigns   Boolean  @default(false) @map("remove_opening_signs")
  splitLongMessages    Boolean  @default(false) @map("split_long_messages")
  messageWindowSeconds Int      @default(4) @map("message_window_seconds")
  disableReactionReplies Boolean @default(false) @map("disable_reaction_replies")
  updatedAt            DateTime @map("updated_at")

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model TenantChannel {
  id                  String      @id @db.Uuid
  tenantId            String      @map("tenant_id") @db.Uuid
  type                ChannelType
  chatwootInboxId     Int         @map("chatwoot_inbox_id")
  configEncryptedJson String      @map("config_encrypted_json") @db.Text
  evolutionInstance   String?     @map("evolution_instance")
  createdAt           DateTime    @map("created_at")
  updatedAt           DateTime    @map("updated_at")
  deletedAt           DateTime?   @map("deleted_at")

  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([evolutionInstance])
  @@map("tenant_channels")
}

enum LeadStage {
  new
  contacted
  qualified
  proposal
  won
  lost
}

model ConversationLink {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  chatwootConversationId Int                @map("chatwoot_conversation_id")
  chatwootContactId      Int?               @map("chatwoot_contact_id")
  phone                  String?
  contactName            String?            @map("contact_name")
  lastMessage            String?            @map("last_message") @db.Text
  stage                  LeadStage          @default(new)
  notes                  String?            @db.Text
  tags                   String[]           @default([])
  crmLeadId              String?            @map("crm_lead_id")
  wahaChatId             String?            @map("waha_chat_id")
  handoffActive          Boolean            @default(false) @map("handoff_active")
  source                 ConversationSource @default(chatwoot)
  assignedAgentId        String?            @map("assigned_agent_id") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages               Message[]
  appointments           Appointment[]

  @@unique([tenantId, chatwootConversationId])
  @@index([tenantId, stage])
  @@index([tenantId, phone])
  @@index([tenantId, source])
  @@index([tenantId, assignedAgentId])
  @@map("conversation_links")
}

enum RoutingRuleType {
  round_robin
  fixed
  geo
}

model RoutingRule {
  id               String          @id @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  name             String
  type             RoutingRuleType
  conditionsJson   Json            @map("conditions_json") @db.JsonB
  assignedAgentId  String?         @map("assigned_agent_id") @db.Uuid
  priority         Int             @default(0)
  isActive         Boolean         @default(true) @map("is_active")
  roundRobinIndex  Int             @default(0) @map("round_robin_index")
  createdAt        DateTime        @map("created_at")
  updatedAt        DateTime        @map("updated_at")

  @@index([tenantId, isActive, priority])
  @@map("routing_rules")
}

model Message {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  conversationLinkId String           @map("conversation_link_id") @db.Uuid
  direction          MessageDirection
  content            String           @db.Text
  senderName         String?          @map("sender_name")
  timestamp          DateTime         @default(now())

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationLink   ConversationLink @relation(fields: [conversationLinkId], references: [id], onDelete: Cascade)

  @@index([conversationLinkId, timestamp])
  @@map("messages")
}

model UsageRecord {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  period    String
  messages  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@map("usage_records")
}

model KnowledgeEntry {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  category  String   @default("general")
  title     String
  content   String   @db.Text
  enabled   Boolean  @default(true)
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, enabled])
  @@map("knowledge_entries")
}

model DailyUsage {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  date      DateTime @db.Date
  messages  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@map("daily_usage")
}

model BaileysAuth {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  dataKey  String @map("data_key")
  dataVal  String @map("data_val") @db.Text

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dataKey])
  @@map("baileys_auth")
}

// ── Calendar models (read + write from bot) ──

enum UserRole {
  super_admin
  owner
  admin
  agent
}

model TenantUser {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  email         String
  name          String   @default("")
  passwordHash  String?  @map("password_hash")
  googleId      String?  @unique @map("google_id")
  role          UserRole @default(agent)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant                       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendarProfessionalServices CalendarProfessionalService[]
  calendarSchedules            CalendarSchedule[]
  calendarBlockedTimes         CalendarBlockedTime[]
  appointments                 Appointment[] @relation("AppointmentProfessional")

  @@unique([tenantId, email])
  @@index([email])
  @@map("tenant_users")
}

model CalendarConfig {
  tenantId          String   @id @map("tenant_id") @db.Uuid
  timezone          String   @default("America/Argentina/Buenos_Aires")
  slotBufferMinutes Int      @default(15) @map("slot_buffer_minutes")
  minAdvanceHours   Int      @default(2) @map("min_advance_hours")
  maxAdvanceDays    Int      @default(30) @map("max_advance_days")
  reminderChannel   String?  @map("reminder_channel")
  reminderMinutes1  Int      @default(60) @map("reminder_minutes_1")
  reminderMinutes2  Int?     @map("reminder_minutes_2")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("calendar_config")
}

model CalendarService {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  durationMinutes Int      @map("duration_minutes")
  price           Decimal? @db.Decimal(10, 2)
  color           String   @default("#6366f1")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionals   CalendarProfessionalService[]
  appointments    Appointment[]

  @@index([tenantId, isActive])
  @@map("calendar_services")
}

model CalendarProfessionalService {
  id             String          @id @default(uuid()) @db.Uuid
  professionalId String          @map("professional_id") @db.Uuid
  serviceId      String          @map("service_id") @db.Uuid

  professional   TenantUser      @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        CalendarService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@map("calendar_professional_services")
}

model CalendarSchedule {
  id             String     @id @default(uuid()) @db.Uuid
  professionalId String     @map("professional_id") @db.Uuid
  dayOfWeek      Int        @map("day_of_week")
  startTime      String     @map("start_time")
  endTime        String     @map("end_time")
  breakStart     String?    @map("break_start")
  breakEnd       String?    @map("break_end")

  professional   TenantUser @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("calendar_schedules")
}

model CalendarBlockedTime {
  id             String     @id @default(uuid()) @db.Uuid
  professionalId String     @map("professional_id") @db.Uuid
  startAt        DateTime   @map("start_at")
  endAt          DateTime   @map("end_at")
  reason         String?

  professional   TenantUser @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, startAt, endAt])
  @@map("calendar_blocked_times")
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum AppointmentSource {
  chat_ai
  manual
  web
}

model Appointment {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  serviceId          String            @map("service_id") @db.Uuid
  professionalId     String            @map("professional_id") @db.Uuid
  conversationLinkId String?           @map("conversation_link_id") @db.Uuid
  clientName         String            @map("client_name")
  clientPhone        String?           @map("client_phone")
  startAt            DateTime          @map("start_at")
  endAt              DateTime          @map("end_at")
  status             AppointmentStatus @default(pending)
  source             AppointmentSource @default(manual)
  notes              String?           @db.Text
  reminderSentAt     DateTime?         @map("reminder_sent_at")
  reminder2SentAt    DateTime?         @map("reminder2_sent_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service            CalendarService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional       TenantUser        @relation("AppointmentProfessional", fields: [professionalId], references: [id], onDelete: Cascade)
  conversationLink   ConversationLink? @relation(fields: [conversationLinkId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([professionalId, startAt])
  @@index([tenantId, status])
  @@map("appointments")
}
